#!/usr/bin/env sh

set -e

echo "🔍 Semgrep — فحص القواعد الصارمة..."
# Force Python UTF-8 mode so semgrep can read non-ASCII config files on Windows (cp1252 default).
export PYTHONUTF8=1
export PYTHONIOENCODING=utf-8
if command -v semgrep >/dev/null 2>&1; then
  pnpm run security:semgrep
else
  echo "❌ semgrep غير مثبت محلياً."
  echo "يمكن التجاوز فقط في حالة الطوارئ عبر SKIP_SEMGREP=1 git push ..."
  if [ "${SKIP_SEMGREP:-0}" = "1" ]; then
    echo "⚠️  SKIP_SEMGREP=1 — تخطّي الفحص المحلي."
  else
    exit 1
  fi
fi

echo "🧪 Quality gate — فحص التدقيق والأنواع الرسمي..."
pnpm run lint
pnpm run type-check

echo "✅ Pre-push verification..."
pnpm prepush:verify
