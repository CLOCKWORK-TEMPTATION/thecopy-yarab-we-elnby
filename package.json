  "scripts": {
    "agent:bootstrap": "tsx scripts/agent/bootstrap.ts",
    "agent:guard:start": "tsx scripts/agent/guard.ts --phase=start",
    "agent:guard:step": "tsx scripts/agent/guard.ts --phase=step",
    "agent:guard:verify": "tsx scripts/agent/guard.ts --phase=verify",
    "predev": "pnpm agent:guard:step",
    "predev:all": "pnpm agent:guard:step",
    "predev:web": "pnpm agent:guard:step",
    "predev:backend": "pnpm agent:guard:step",
    "prestart": "pnpm agent:guard:step",
    "prestart:fresh": "pnpm agent:guard:step",
    "predoctor": "pnpm agent:guard:step",
    "preverify:runtime": "pnpm agent:guard:step",
    "prebuild": "pnpm agent:guard:step",
    "pretest": "pnpm agent:guard:step",
    "prelint": "pnpm agent:guard:step",
    "pretype-check": "pnpm agent:guard:step",
    "preprepush:verify": "pnpm agent:guard:step",
    "prevalidate": "pnpm agent:guard:verify",
    "prevalidate:strict": "pnpm agent:guard:verify",
    "preci": "pnpm agent:guard:verify",
    "preagent:start": "pnpm agent:guard:start",
    "preagent:verify": "pnpm agent:guard:verify",
    "preagent:refresh-maps": "pnpm agent:guard:step",
    "preagent:memory:search": "pnpm agent:guard:step",
    "preagent:memory:status": "pnpm agent:guard:step",
    "preagent:memory:verify": "pnpm agent:guard:step",
    "preworkspace:embed": "pnpm agent:guard:step",
    "security:deps": "snyk test --all-projects --severity-threshold=high",
    "security:code": "snyk code test",
    "security:monitor": "snyk monitor --all-projects",
    "security:trivy": "bash scripts/security/trivy-scan.sh",
    "security:trivy:build": "bash scripts/security/trivy-scan.sh --build",
    "security:zap": "bash scripts/security/zap-baseline.sh",
    "security:zap:full": "bash scripts/security/zap-baseline.sh --full",
    "security:env:check": "pnpm --filter @the-copy/backend exec tsx -e \"import('./src/config/env-safe').then(m => { const r = m.runEnvSafeCheck(); if (!r.ok) process.exit(1); })\"",
    "security:secrets": "gitleaks detect --source . --redact --verbose --config=.gitleaks.toml",
    "security:secrets:staged": "gitleaks protect --staged --redact --verbose --config=.gitleaks.toml",
    "security:semgrep": "semgrep scan --config .semgrep --config p/typescript --config p/nodejs --config p/secrets --error --severity=ERROR",
    "security:semgrep:all": "semgrep scan --config .semgrep --config p/typescript --config p/nodejs --config p/secrets",
    "security:all": "pnpm run security:secrets && pnpm run security:semgrep && pnpm run security:deps && pnpm run security:trivy && pnpm run security:zap",
    "agent:verify": "tsx scripts/agent/verify-state.ts",
    "agent:refresh-maps": "tsx scripts/agent/refresh-maps.ts",
    "agent:start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/agent/start-agent.ps1",
    "agent:memory:index": "tsx scripts/agent/code-memory-index.ts",
    "agent:memory:search": "tsx scripts/agent/code-memory-search.ts",
    "agent:memory:status": "tsx scripts/agent/code-memory-status.ts",
    "agent:memory:verify": "tsx scripts/agent/code-memory-verify.ts",
    "agent:memory:watch": "tsx scripts/agent/code-memory-watch.ts",
    "build": "turbo build",
    "dev": "pnpm --filter @the-copy/web dev",
    "dev:watch": "echo 'dev:watch requires a local DOCCCCS install – see README' && exit 1",
    "dev:all": "turbo dev --filter=@the-copy/web --filter=@the-copy/backend",
    "dev:web": "pnpm --filter @the-copy/web dev:next-only",
    "dev:backend": "pnpm --filter @the-copy/backend dev",
    "test": "turbo test",
    "test:strict": "pnpm run test && pnpm run prepush:verify",
    "guard:staged": "node scripts/quality/guard-staged.mjs",
    "guard:budgets": "node scripts/quality/guard-budgets.mjs",
    "list-new-violations": "node scripts/quality/list-new-violations.mjs",
    "list-new-violations:web": "node scripts/quality/list-new-violations.mjs --project=web",
    "list-new-violations:backend": "node scripts/quality/list-new-violations.mjs --project=backend",
    "lint": "turbo lint",
    "lint:strict": "pnpm run lint && pnpm run check:exports",
    "type-check": "turbo type-check",
    "prepush:verify": "pnpm --filter @the-copy/web test:config && pnpm --filter @the-copy/web test:smoke && pnpm --filter @the-copy/backend test:config",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "pnpm --filter @the-copy/web format",
    "format:check": "pnpm --filter @the-copy/web format:check",
    "deps:audit:prod": "pnpm audit --prod --audit-level=high",
    "deps:audit:all": "pnpm audit --audit-level=high",
    "validate": "pnpm run deps:audit:prod && pnpm run format:check && pnpm run lint:strict && pnpm run type-check && pnpm run test:strict && pnpm run build && pnpm run guard:budgets",
    "validate:strict": "pnpm run validate",
    "ci": "pnpm run validate:strict",
    "docker:prod:build": "docker compose --env-file .env.docker build --pull",
    "docker:prod:up": "docker compose --env-file .env.docker up -d --build",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-app.ps1",
    "start:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-app.ps1 -Fresh",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/kill-ports.ps1",
    "start:redis": "powershell -Command \"Start-Process -FilePath '.\\redis\\redis-server.exe' -WindowStyle Minimized\"",
    "check:exports": "node scripts/check-duplicate-exports.mjs",
    "audit:code": "npx tsx scripts/code-auditor.ts",
    "sentry:setup": "npx @sentry/wizard@latest -i nextjs --saas --org me-gj0 --project the-copy",
    "ariana": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-ariana.ps1",
    "ariana:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-ariana.ps1 -WebOnly",
    "ariana:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-ariana.ps1 -BackendOnly",
    "ariana:inplace": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-ariana.ps1 -InPlace",
    "infra:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/infra.ps1 up",
    "infra:down": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/infra.ps1 down",
    "infra:status": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/infra.ps1 status",
    "infra:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/infra.ps1 reset",
    "doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/doctor.ps1",
    "verify:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/doctor.ps1",
    "workspace:embed": "pnpm agent:memory:index",
    "check:line-budget": "node scripts/check-file-line-budget.mjs"
  },
