  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.js --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "apps/backend/**/*.{ts,tsx}": [
      "eslint --config apps/backend/eslint.config.js --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md,yml,yaml}": [
