# مفاتيح ومسارات إعداد مطلوبة أو اختيارية لبايبلاين المحرر
# هذا الملف لا يحتوي أي قيم حقيقية.

# =========================================================
# المطلوب الآن للمسار النشط فعليًا
# =========================================================

# OCR أساسي عبر Mistral: نموذج mistral-ocr-latest
MISTRAL_API_KEY=

# طبقة التصحيح البصري بعد OCR: gemini-2.5-flash
# مطلوب أيضًا افتراضيًا لقناة المراجعة النهائية
GEMINI_API_KEY=


# =========================================================
# مزودات بديلة لقناة المراجعة النهائية
# =========================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# اختيار المزود والنموذج لمراجعة الشك والمراجعة النهائية
# أمثلة:
# FINAL_REVIEW_MODEL=google-genai:gemini-2.5-flash
# FINAL_REVIEW_MODEL=openai:gpt-5
# FINAL_REVIEW_MODEL=anthropic:claude-sonnet-4-5
AGENT_REVIEW_MODEL=google-genai:gemini-2.5-flash
FINAL_REVIEW_MODEL=google-genai:gemini-2.5-flash

# نموذج احتياطي اختياري للمراجعة النهائية
FINAL_REVIEW_FALLBACK_MODEL=


# =========================================================
# طبقات QA البصرية الاختيارية (compare + kimi-judge)
# مطفأة افتراضيًا — فعّلها فقط إذا أردت مقارنة/حكم بصري بعد OCR
# =========================================================

# مفتاح Moonshot (Kimi) لطبقة الحكم البصري
MOONSHOT_API_KEY=

# نماذج طبقات QA
PDF_VISION_COMPARE_MODEL=
PDF_VISION_JUDGE_MODEL=

# طبقة التصحيح البصري بعد OCR
PDF_VISION_PROOFREAD_MODEL=gemini-2.5-flash


# =========================================================
# إعدادات اختيارية لبايبلاين OCR
# =========================================================

# النموذج الاحتياطي إذا رجع المسار إلى Gemini OCR المباشر
PDF_OCR_AGENT_GEMINI_MODEL=gemini-2.5-flash
PDF_OCR_ENABLE_VISION_PROOFREAD=true
PDF_OCR_ENABLE_VISION_QA=false


# =========================================================
# إعدادات MCP الاختيارية داخل مسار فتح PDF القديم
# =========================================================

OPEN_PDF_AGENT_ENABLE_MCP_STAGE=true
OPEN_PDF_AGENT_ENABLE_MCP_LLM_REVIEW=false
OPEN_PDF_AGENT_LLM_MODEL=
OPEN_PDF_AGENT_LLM_REFERENCE_PATH=
KIMI_THINKING_MODE=disabled


# =========================================================
# ملاحظات مهمة
# =========================================================

# الكرنك لا يحتاج مفتاح API.
# لكنه يحتاج Python 3.12+.

# مسار DOC يحتاج antiword.
# مسار PDF يحتاج pdftoppm.
