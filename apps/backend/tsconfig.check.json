{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "rootDir": ".",
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo.check"
  },
  "include": [
    "src/agents/**/*.ts",
    "src/examples/**/*.ts",
    "src/mcp-server.ts",
    "src/scripts/**/*.ts",
    "src/test/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "db-performance-analysis"
  ],
  "files": []
}
