{
  "name": "@the-copy/backend",
  "version": "1.0.0",
  "description": "Backend API for The Copy - Drama Analysis Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "pnpm exec tsc-watch --project tsconfig.build.json --onSuccess \"node dist/server.js\"",
    "dev:editor-runtime": "pnpm run dev",
    "dev:mcp": "tsx watch src/mcp-server.ts",
    "mcp": "tsx src/mcp-server.ts",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && pnpm exec esbuild src/server.ts --bundle --platform=node --format=cjs --target=node20 --packages=external --tsconfig=tsconfig.build.json --outfile=dist/server.js",
    "start:editor-runtime": "pnpm run start",
    "start": "node dist/server.js",
    "start:prod": "pnpm run db:migrate && node dist/server.js",
    "test": "vitest run --configLoader runner",
    "test:config": "vitest run src/config/env.test.ts",
    "test:coverage": "vitest run --configLoader runner --coverage",
    "lint": "node ../../scripts/quality/eslint-contract.mjs --project=backend",
    "lint:fix": "node scripts/lint-chunked.mjs --fix",
    "lint:strict": "node scripts/lint-chunked.mjs --max-warnings=0",
    "type-check": "node ../../scripts/quality/typecheck-contract.mjs --project=backend",
    "type-check:full": "node ../../scripts/quality/typecheck-contract.mjs --project=backend --full",
    "type-check:strict": "tsc -p tsconfig.check.json --noEmit --pretty false && tsc -p tsconfig.build.json --noEmit --pretty false && tsc -p tsconfig.budget-runtime.json --noEmit --pretty false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "perf:setup": "bash db-performance-analysis/setup-database.sh",
    "perf:seed": "tsx db-performance-analysis/seed-test-data.ts",
    "perf:baseline": "tsx db-performance-analysis/run-performance-analysis.ts baseline",
    "perf:apply-indexes": "bash db-performance-analysis/apply-indexes.sh",
    "perf:post-optimization": "tsx db-performance-analysis/run-performance-analysis.ts post-optimization",
    "perf:compare": "tsx db-performance-analysis/compare-results.ts",
    "logs:sanitize": "tsx scripts/sanitize-historical-logs.ts",
    "logs:sanitize:dry-run": "DRY_RUN=true tsx scripts/sanitize-historical-logs.ts"
  },
  "keywords": [
    "drama",
    "analysis",
    "ai",
    "arabic",
    "screenplay"
  ],
  "author": "The Copy Team",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/openai": "^3.0.50",
    "@anthropic-ai/sdk": "^0.74.0",
    "@bull-board/api": "^6.16.2",
    "@bull-board/express": "^6.16.2",
    "@bull-board/ui": "^6.16.2",
    "@google/genai": "^0.8.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/openai": "^1.2.13",
    "@mistralai/mistralai": "^1.15.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@neondatabase/serverless": "^1.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation-fetch": "^0.208.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-web": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@sentry/core": "^10.32.1",
    "@sentry/node": "^10.32.1",
    "@sentry/profiling-node": "^10.32.1",
    "@the-copy/core-memory": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "ai": "^6.0.141",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.4",
    "compression": "^1.7.4",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "dotenv-safe": "^9.1.0",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.45.2",
    "eventemitter3": "^5.0.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.2",
    "express-session": "^1.18.2",
    "glob": "^11.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "mammoth": "^1.11.0",
    "minimatch": "^9.0.7",
    "module-alias": "^2.2.3",
    "mongodb": "^7.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.5",
    "openai": "^6.32.0",
    "otplib": "^12.0.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "redis": "^5.10.0",
    "sharp": "^0.34.5",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.3",
    "tiktoken": "^1.0.20",
    "tsx": "^4.7.0",
    "uuid": "^14.0.0",
    "weaviate-client": "^3.5.0",
    "winston": "^3.11.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/dotenv-safe": "^8.1.6",
    "@types/express": "^5.0.5",
    "@types/glob": "^8.1.0",
    "@types/minimatch": "^5.1.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "supertest": "^7.1.3",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "ws": "^8.18.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "_moduleAliases": {
    "@": "dist",
    "@core": "dist/services/agents/core"
  },
  "optionalDependencies": {
    "winax": "^3.6.8"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
