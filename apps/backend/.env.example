# ===================================================================
# apps/backend/.env.example
# ===================================================================
# نموذج متغيّرات البيئة المطلوبة لتشغيل الخادم الخلفي.
# انسخ هذا الملف إلى apps/backend/.env وعدّل القيم.
# dotenv-safe يستخدم هذا الملف للتحقق من اكتمال المتغيرات قبل الإقلاع.
# ===================================================================

# --- Runtime ---------------------------------------------------------
NODE_ENV=development
PORT=3001

# --- Database (PostgreSQL / Neon) ------------------------------------
DATABASE_URL=postgresql://thecopy:thecopy_dev@localhost:5433/thecopy_dev

# --- Local infrastructure --------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
WEAVIATE_URL=http://localhost:8080
WEAVIATE_REQUIRED=false
QDRANT_URL=http://localhost:6333
PERSISTENT_MEMORY_INFRA_REQUIRED=false
MEMORY_INFRA_REQUIRED=false

# --- Authentication --------------------------------------------------
# في الإنتاج يجب ألا يقل عن 32 حرفاً ولا يحتوي على 'CHANGE-THIS' أو 'dev-secret'
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# --- BREAKAPP -------------------------------------------------------
# ملاحظة: BREAKAPP يستخدم JWT_SECRET الحالي لـ access tokens،
# و refresh tokens تُخزَّن كـ SHA-256 hash لقيمة عشوائية من crypto.randomBytes(48)،
# لذلك لا يلزم سر مستقل حالياً. أي متغيرات خاصة بـ BREAKAPP ستضاف هنا لاحقاً.

# --- CORS ------------------------------------------------------------
CORS_ORIGIN=http://localhost:5000,http://localhost:9002

# --- Rate Limiting ---------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Frontend reference ----------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
