{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/mcp-sdk-compat.d.ts",
    "src/types/module-alias.d.ts",
    "src/bootstrap/**/*.ts",
    "src/bootstrap/**/*.tsx",
    "src/bootstrap/**/*.js",
    "src/bootstrap/**/*.mjs",
    "src/bootstrap/**/*.cjs"
  ],
  "exclude": ["node_modules", "dist"]
}
