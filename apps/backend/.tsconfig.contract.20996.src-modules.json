{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "tsBuildInfoFile": "./.tsbuildinfo.contract.20996.src-modules"
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/module-alias.d.ts",
    "src/modules/**/*.ts",
    "src/modules/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
