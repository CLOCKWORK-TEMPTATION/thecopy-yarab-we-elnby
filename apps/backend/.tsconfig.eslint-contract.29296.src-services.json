{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/mcp-sdk-compat.d.ts",
    "src/types/module-alias.d.ts",
    "src/services/**/*.ts",
    "src/services/**/*.tsx",
    "src/services/**/*.js",
    "src/services/**/*.mjs",
    "src/services/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
