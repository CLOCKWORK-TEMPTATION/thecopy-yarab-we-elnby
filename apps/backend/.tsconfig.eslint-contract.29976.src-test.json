{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/mcp-sdk-compat.d.ts",
    "src/types/module-alias.d.ts",
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/test/**/*.js",
    "src/test/**/*.mjs",
    "src/test/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
