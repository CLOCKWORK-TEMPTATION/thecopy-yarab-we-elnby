{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/module-alias.d.ts",
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx",
    "src/__tests__/**/*.js",
    "src/__tests__/**/*.mjs",
    "src/__tests__/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
