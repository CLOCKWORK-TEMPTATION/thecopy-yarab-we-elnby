{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/module-alias.d.ts",
    "scripts/**/*.ts",
    "scripts/**/*.tsx",
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
