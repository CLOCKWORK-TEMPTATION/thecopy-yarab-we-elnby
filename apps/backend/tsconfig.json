{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noUncheckedIndexedAccess": true,
    "strictPropertyInitialization": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/db": ["src/db/index.ts"],
      "@/db/*": ["src/db/*"],
      "@/*": ["src/*"],
      "@core/*": ["src/services/agents/core/*"],
      "@/types/*": ["src/types/*"],
      "@/services/*": ["src/services/*"],
      "@/controllers/*": ["src/controllers/*"],
      "@/middleware/*": ["src/middleware/*"],
      "@/utils/*": ["src/utils/*"],
      "@/lib/*": ["src/lib/*"],
      "@the-copy/shared": ["../../packages/shared/src"],
      "@the-copy/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "files": [
    "src/server.ts",
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/module-alias.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**",
    "src/test/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/agents/**",
    "src/examples/**",
    "src/mcp-server.ts",
    "src/scripts/**",
    "scripts/**"
  ]
}
