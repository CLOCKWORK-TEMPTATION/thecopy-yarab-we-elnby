{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/global.d.ts",
    "src/env.d.ts",
    "src/types/env.d.ts",
    "src/types/module-alias.d.ts",
    "src/queues/**/*.ts",
    "src/queues/**/*.tsx",
    "src/queues/**/*.js",
    "src/queues/**/*.mjs",
    "src/queues/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
